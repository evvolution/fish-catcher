// Prisma is intentionally initialized without models for now.
// Add your first model here when the domain becomes clear.

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "mysql"
}

enum UserKind {
  MEMBER
  GUEST
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuthProvider {
  WECHAT
  GOOGLE
  PHONE
  GUEST
}

enum AuthIdentityStatus {
  ACTIVE
  REVOKED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum VerificationScene {
  SIGN_IN
  BIND_PHONE
  RESET_PASSWORD
}

enum DimensionKind {
  TIME_OF_DAY
  INDUSTRY
  MOOD
  STYLE
  SOLAR_TERM
  HOLIDAY
  WEATHER
  CARD_RARITY
  GREETING_PHASE
}

enum CopywritingKind {
  RESULT
  CARD
  GREETING
  GUIDE
}

model User {
  id           String         @id @default(cuid()) @db.VarChar(191)
  kind         UserKind       @default(MEMBER)
  role         UserRole       @default(USER)
  status       UserStatus     @default(ACTIVE)
  displayName  String         @default("摸鱼用户") @map("display_name") @db.VarChar(50)
  avatarUrl    String?        @map("avatar_url") @db.VarChar(255)
  lastLoginAt  DateTime?      @map("last_login_at")
  registeredAt DateTime       @default(now()) @map("registered_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  profile      UserProfile?
  identities   AuthIdentity[]
  sessions     UserSession[]

  @@index([kind, status], map: "idx_users_kind_status")
  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model UserProfile {
  id                  String   @id @default(cuid()) @db.VarChar(191)
  userId              String   @unique @map("user_id") @db.VarChar(191)
  nickname            String?  @db.VarChar(50)
  bio                 String?  @db.VarChar(255)
  city                String?  @db.VarChar(64)
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  preferences         Json?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AuthIdentity {
  id              String             @id @default(cuid()) @db.VarChar(191)
  userId          String             @map("user_id") @db.VarChar(191)
  provider        AuthProvider
  providerUserId  String             @map("provider_user_id") @db.VarChar(191)
  providerUnionId String?            @map("provider_union_id") @db.VarChar(191)
  email           String?            @db.VarChar(191)
  phone           String?            @db.VarChar(32)
  status          AuthIdentityStatus @default(ACTIVE)
  isPrimary       Boolean            @default(false) @map("is_primary")
  metadata        Json?
  lastUsedAt      DateTime?          @map("last_used_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "uniq_auth_provider_user")
  @@index([userId, status], map: "idx_auth_identities_user_status")
  @@index([provider, lastUsedAt], map: "idx_auth_identities_provider_last_used")
  @@map("auth_identities")
}

model UserSession {
  id           String        @id @default(cuid()) @db.VarChar(191)
  userId       String        @map("user_id") @db.VarChar(191)
  sessionToken String        @unique @map("session_token") @db.VarChar(191)
  status       SessionStatus @default(ACTIVE)
  platform     String        @default("h5") @db.VarChar(32)
  ipAddress    String?       @map("ip_address") @db.VarChar(64)
  userAgent    String?       @map("user_agent") @db.VarChar(255)
  lastSeenAt   DateTime?     @map("last_seen_at")
  expiresAt    DateTime      @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status], map: "idx_user_sessions_user_status")
  @@index([expiresAt], map: "idx_user_sessions_expires_at")
  @@map("user_sessions")
}

model PhoneVerificationCode {
  id         String            @id @default(cuid()) @db.VarChar(191)
  scene      VerificationScene
  target     String            @db.VarChar(32)
  codeHash   String            @map("code_hash") @db.VarChar(191)
  attempts   Int               @default(0)
  sentAt     DateTime          @default(now()) @map("sent_at")
  expiresAt  DateTime          @map("expires_at")
  consumedAt DateTime?         @map("consumed_at")
  metadata   Json?

  @@index([target, scene], map: "idx_phone_codes_target_scene")
  @@index([expiresAt], map: "idx_phone_codes_expires_at")
  @@map("phone_verification_codes")
}

model MomentActivity {
  id          String             @id @default(cuid()) @db.VarChar(191)
  slug        String             @unique @db.VarChar(64)
  name        String             @db.VarChar(64)
  iconKey     String             @map("icon_key") @db.VarChar(64)
  description String?            @db.VarChar(255)
  prompt      String?            @db.VarChar(255)
  colorStart  String?            @map("color_start") @db.VarChar(16)
  colorEnd    String?            @map("color_end") @db.VarChar(16)
  sortOrder   Int                @default(0) @map("sort_order")
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  copyEntries CopywritingEntry[]
  backgrounds BackgroundAsset[]

  @@index([sortOrder, isActive], map: "idx_moment_activities_sort_active")
  @@map("moment_activities")
}

model DimensionGroup {
  id          String            @id @default(cuid()) @db.VarChar(191)
  key         String            @unique @db.VarChar(64)
  label       String            @db.VarChar(64)
  description String?           @db.VarChar(255)
  kind        DimensionKind
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  options     DimensionOption[]

  @@index([kind, sortOrder], map: "idx_dimension_groups_kind_sort")
  @@map("dimension_groups")
}

model DimensionOption {
  id              String                     @id @default(cuid()) @db.VarChar(191)
  groupId         String                     @map("group_id") @db.VarChar(191)
  slug            String                     @db.VarChar(64)
  label           String                     @db.VarChar(64)
  description     String?                    @db.VarChar(255)
  sortOrder       Int                        @default(0) @map("sort_order")
  isActive        Boolean                    @default(true) @map("is_active")
  metadata        Json?
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  group           DimensionGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  copyLinks       CopywritingEntryDimension[]
  backgroundLinks BackgroundAssetDimension[]

  @@unique([groupId, slug], map: "uniq_dimension_options_group_slug")
  @@index([groupId, sortOrder, isActive], map: "idx_dimension_options_group_sort_active")
  @@map("dimension_options")
}

model CopywritingEntry {
  id             String                       @id @default(cuid()) @db.VarChar(191)
  slug           String                       @unique @db.VarChar(80)
  kind           CopywritingKind
  activityId     String?                      @map("activity_id") @db.VarChar(191)
  title          String                       @db.VarChar(120)
  content        String                       @db.Text
  notes          String?                      @db.VarChar(255)
  minDurationSec Int?                         @map("min_duration_sec")
  maxDurationSec Int?                         @map("max_duration_sec")
  weight         Int                          @default(100)
  dropRate       Int                          @default(0) @map("drop_rate")
  isActive       Boolean                      @default(true) @map("is_active")
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")
  activity       MomentActivity?              @relation(fields: [activityId], references: [id], onDelete: SetNull)
  dimensions     CopywritingEntryDimension[]

  @@index([kind, isActive], map: "idx_copywriting_entries_kind_active")
  @@index([activityId, kind], map: "idx_copywriting_entries_activity_kind")
  @@map("copywriting_entries")
}

model CopywritingEntryDimension {
  copywritingEntryId String           @map("copywriting_entry_id") @db.VarChar(191)
  optionId           String           @map("option_id") @db.VarChar(191)
  createdAt          DateTime         @default(now()) @map("created_at")
  copywritingEntry   CopywritingEntry @relation(fields: [copywritingEntryId], references: [id], onDelete: Cascade)
  option             DimensionOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([copywritingEntryId, optionId])
  @@index([optionId], map: "idx_copywriting_entry_dimensions_option")
  @@map("copywriting_entry_dimensions")
}

model BackgroundAsset {
  id               String                     @id @default(cuid()) @db.VarChar(191)
  slug             String                     @unique @db.VarChar(80)
  title            String                     @db.VarChar(120)
  imagePath        String                     @map("image_path") @db.VarChar(255)
  sourceName       String                     @map("source_name") @db.VarChar(64)
  sourcePageUrl    String                     @map("source_page_url") @db.VarChar(255)
  photographerName String?                    @map("photographer_name") @db.VarChar(120)
  licenseLabel     String?                    @map("license_label") @db.VarChar(120)
  blurColor        String?                    @map("blur_color") @db.VarChar(16)
  description      String?                    @db.VarChar(255)
  activityId       String?                    @map("activity_id") @db.VarChar(191)
  sortOrder        Int                        @default(0) @map("sort_order")
  isActive         Boolean                    @default(true) @map("is_active")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  activity         MomentActivity?            @relation(fields: [activityId], references: [id], onDelete: SetNull)
  dimensions       BackgroundAssetDimension[]

  @@index([activityId, sortOrder, isActive], map: "idx_background_assets_activity_sort_active")
  @@map("background_assets")
}

model BackgroundAssetDimension {
  backgroundAssetId String          @map("background_asset_id") @db.VarChar(191)
  optionId          String          @map("option_id") @db.VarChar(191)
  createdAt         DateTime        @default(now()) @map("created_at")
  backgroundAsset   BackgroundAsset @relation(fields: [backgroundAssetId], references: [id], onDelete: Cascade)
  option            DimensionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([backgroundAssetId, optionId])
  @@index([optionId], map: "idx_background_asset_dimensions_option")
  @@map("background_asset_dimensions")
}

model CityGuide {
  id          String      @id @default(cuid()) @db.VarChar(191)
  slug        String      @unique @db.VarChar(64)
  name        String      @db.VarChar(64)
  description String?     @db.VarChar(255)
  sortOrder   Int         @default(0) @map("sort_order")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  snacks      CitySnack[]

  @@index([sortOrder, isActive], map: "idx_city_guides_sort_active")
  @@map("city_guides")
}

model CitySnack {
  id          String    @id @default(cuid()) @db.VarChar(191)
  cityId      String    @map("city_id") @db.VarChar(191)
  slug        String    @db.VarChar(64)
  name        String    @db.VarChar(64)
  unitLabel   String    @default("份") @map("unit_label") @db.VarChar(16)
  priceCents  Int       @map("price_cents")
  description String?   @db.VarChar(255)
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  city        CityGuide @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, slug], map: "uniq_city_snacks_city_slug")
  @@index([cityId, sortOrder, isActive], map: "idx_city_snacks_city_sort_active")
  @@map("city_snacks")
}
