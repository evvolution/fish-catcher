{
  "name": "fish-catcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "next dev",
    "prebuild": "npm run prisma:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:quotes": "node scripts/build-gap-copy-corpus.mjs",
    "build:forums": "node scripts/build-forum-copy.mjs",
    "build:fishes": "node scripts/build-fish-catalog.mjs && node scripts/apply-fish-safety-profiles.mjs",
    "build:assets": "node scripts/build-asset-manifest.mjs",
    "check:fishes": "node scripts/check-fish-catalog.mjs",
    "check:assets": "node scripts/build-asset-manifest.mjs --check",
    "check:quotes": "node scripts/check-gap-quotes.mjs",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "mariadb": "^3.4.5",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "typescript": "^5"
  }
}
