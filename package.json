{
  "name": "moyu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "nuxt dev",
    "prebuild": "npm run prisma:generate",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "backend:dev": "npm run dev",
    "backend:build": "npm run build",
    "uni:dev:h5": "npm run dev:h5 --workspace @moyu/uniapp",
    "uni:build:h5": "npm run build:h5 --workspace @moyu/uniapp",
    "uni:build:mp-weixin": "npm run build:mp-weixin --workspace @moyu/uniapp",
    "uni:build:app": "npm run build:app --workspace @moyu/uniapp",
    "uni:build:dmg": "npm run build:dmg --workspace @moyu/uniapp",
    "uni:typecheck": "npm run typecheck --workspace @moyu/uniapp",
    "lint": "eslint scripts",
    "typecheck": "nuxt typecheck",
    "build:quotes": "node scripts/build-moyu-copy-corpus.mjs",
    "build:forums": "node scripts/build-forum-copy.mjs",
    "build:fishes": "node scripts/build-fish-catalog.mjs && node scripts/apply-fish-safety-profiles.mjs",
    "build:regions": "node scripts/build-regional-catalog.mjs",
    "build:assets": "node scripts/build-asset-manifest.mjs",
    "check:fishes": "node scripts/check-fish-catalog.mjs",
    "check:regions": "node scripts/check-regional-catalog.mjs",
    "check:backpack": "node --experimental-strip-types scripts/check-food-backpack.mjs",
    "check:assets": "node scripts/build-asset-manifest.mjs --check",
    "check:deployment": "node --experimental-strip-types scripts/check-deployment-boundaries.mjs",
    "check:server-deployment": "node scripts/check-server-deployment.mjs",
    "check:quotes": "node scripts/check-moyu-quotes.mjs",
    "postinstall": "prisma generate && nuxt prepare",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "h3": "1.15.11",
    "mariadb": "^3.4.5",
    "nuxt": "4.5.0",
    "vue": "3.5.40",
    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "postcss": "^8.5.8",
    "prisma": "^7.6.0",
    "sharp": "0.35.3",
    "typescript": "^5",
    "vue-tsc": "3.3.7"
  }
}
