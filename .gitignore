# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# nuxt
/.nuxt/
/.output/
/.next/

# production
/build
**/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!/apps/uniapp/.env.development
!/apps/uniapp/.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo

# prisma
/src/generated/prisma

/src/generated/prisma
